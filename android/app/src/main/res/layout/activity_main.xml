<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- Connect form -->
    <ScrollView
        android:id="@+id/connectForm"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp"
                android:text="Connect directly to a remoteagent instance on your LAN"
                android:textColor="@color/text_faint"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <Button
                    android:id="@+id/tabNewButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="New Connection"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:textColor="@color/btn_primary_text" />

                <Button
                    android:id="@+id/tabHistoryButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="History"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:textColor="@color/btn_secondary_text" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/historySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/newConnectionSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name (optional)"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/nameInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_faint"
                android:hint="Living room laptop"
                android:inputType="textNoSuggestions"
                android:singleLine="true"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Host (LAN IP)"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/hostInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_faint"
                android:hint="192.168.1.20"
                android:inputType="textNoSuggestions"
                android:singleLine="true"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Port"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/portInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_faint"
                android:hint="8791"
                android:inputType="number"
                android:singleLine="true"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Token"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/tokenInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_faint"
                android:hint="printed by remoteagent.exe"
                android:inputType="textNoSuggestions"
                android:singleLine="true"
                android:fontFamily="monospace"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/connectButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_button_primary"
                android:text="Connect"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/btn_primary_text" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@color/text_faint"
                android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Viewer -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/viewerContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/backButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_button_secondary"
                android:text="Back"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:paddingHorizontal="14dp"
                android:textColor="@color/btn_secondary_text" />

            <TextView
                android:id="@+id/deviceNameText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/connStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_pill"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="connecting"
                android:textColor="@color/status_yellow_text"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/screenImage"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="#000000"
            android:scaleType="fitCenter"
            android:contentDescription="@null"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 1x1 offscreen-ish EditText purely to drive the IME; text is
             relayed to the agent as it's typed then cleared (see MainActivity). -->
        <EditText
            android:id="@+id/imeCapture"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:background="@null"
            android:textColor="@android:color/transparent"
            android:cursorVisible="false"
            android:inputType="textMultiLine|textNoSuggestions"
            android:imeOptions="actionNone"
            android:maxLines="1000"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageButton
            android:id="@+id/keyboardButton"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_margin="16dp"
            android:background="@drawable/bg_fab_circle"
            android:src="@android:drawable/ic_menu_edit"
            android:contentDescription="Show keyboard"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
